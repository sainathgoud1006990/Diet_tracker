# Copy to .env and fill in values for local development

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/diettrack

# Random secret for session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=your-secret-here

# Replit project ID — used as the OIDC client ID for Replit Auth
# Find this in your Replit project's Secrets tab or .env panel
REPL_ID=your-repl-id-here

# Set to production when deploying
NODE_ENV=production
